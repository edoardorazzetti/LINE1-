# ── 10. FIGURE 2 — ORF1p vs ORF2p scatter by grade ───────────────────────────
cat("    Fig 2: ORF1 vs ORF2 scatter\n")

orf_scat <- adn_df %>%
  dplyr::filter(!is.na(ORF1p), !is.na(ORF2p)) %>%
  dplyr::mutate(Grade = ifelse(is.na(Grade) | Grade == "",

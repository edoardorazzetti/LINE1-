                "ORF2p"   = "#5B8DB8")

# ── 4. METADATA ───────────────────────────────────────────────────────────────
cat("[ 1/8 ] Loading metadata...\n")
meta <- as.data.frame(read_excel(PATH_META))
rownames(meta) <- meta[[1]]
meta <- meta[, -1]

adenoma_mask <- grepl("Adenoma$", meta$Tissue) &
                !grepl("adjacent", meta$Tissue, ignore.case = TRUE)
braf_mask    <- grepl("Mutated", meta$BRAF, ignore.case = TRUE)
adj_mask     <- grepl("Adenoma adjacent", meta$Tissue, ignore.case = TRUE)

adenoma_samples  <- rownames(meta)[adenoma_mask & !braf_mask]
adjacent_samples <- rownames(meta)[adj_mask]
braf_excluded    <- rownames(meta)[adenoma_mask & braf_mask]

cat(sprintf("    Adenomas (excl. BRAF): %d\n", length(adenoma_samples)))
cat(sprintf("    BRAF excluded:         %s\n", paste(braf_excluded, collapse = ", ")))
cat(sprintf("    Adenoma-adjacent:      %d\n", length(adjacent_samples)))

# ── 5. EXPRESSION DATA ────────────────────────────────────────────────────────
cat("[ 2/8 ] Loading expression data (TPM)...\n")
full_raw   <- read.csv(PATH_FULL, row.names = 1, check.names = FALSE,
                       stringsAsFactors = FALSE)
expr_raw   <- full_raw[-(1:2), ]
ids_full   <- sub("\\..*", "", rownames(full_raw)[-(1:2)])
target_ids <- c(SIRT6_TR, LDHA_TR, PDK1_TR, PDK3_TR, L1MET_ID, MET_ID)

keep_tr    <- ids_full %in% target_ids
expr_small <- as.data.frame(apply(expr_raw[keep_tr, ], 2, as.numeric))
ids_small  <- ids_full[keep_tr]

# Helper: mean TPM across transcripts for a given sample vector
get_expr <- function(tr_set, label, samples) {
  rows <- expr_small[ids_small %in% tr_set,
                     colnames(expr_small) %in% samples, drop = FALSE]
  cat(sprintf("    %s: %d/%d transcripts found\n", label, nrow(rows), length(tr_set)))
  if (nrow(rows) == 0) return(setNames(rep(NA_real_, length(samples)), samples))
  colMeans(rows, na.rm = TRUE)[samples]
}

# Adenomas
sirt6_adn <- get_expr(SIRT6_TR, "SIRT6",  adenoma_samples)
ldha_adn  <- get_expr(LDHA_TR,  "LDHA",   adenoma_samples)
pdk1_adn  <- get_expr(PDK1_TR,  "PDK1",   adenoma_samples)
pdk3_adn  <- get_expr(PDK3_TR,  "PDK3",   adenoma_samples)
l1met_adn <- get_expr(L1MET_ID, "L1-MET", adenoma_samples)
met_adn   <- get_expr(MET_ID,   "MET",    adenoma_samples)

# Adjacent
sirt6_adj <- get_expr(SIRT6_TR, "SIRT6",  adjacent_samples)
ldha_adj  <- get_expr(LDHA_TR,  "LDHA",   adjacent_samples)
pdk1_adj  <- get_expr(PDK1_TR,  "PDK1",   adjacent_samples)
pdk3_adj  <- get_expr(PDK3_TR,  "PDK3",   adjacent_samples)
l1met_adj <- get_expr(L1MET_ID, "L1-MET", adjacent_samples)
met_adj   <- get_expr(MET_ID,   "MET",    adjacent_samples)

# ── 6. LINE-1 ORF PROXIES (DESeq2 VST) ───────────────────────────────────────
cat("[ 3/8 ] Normalizing LINE-1 counts with DESeq2 VST...\n")
rep_raw     <- read.table(PATH_REPEAT, sep = "\t", header = TRUE,
                          row.names = 1, check.names = FALSE)
rep_adenoma <- rep_raw[, colnames(rep_raw) %in% adenoma_samples]
cat(sprintf("    Samples in repeat file: %d\n", ncol(rep_adenoma)))

count_mat <- round(as.matrix(rep_adenoma))
count_mat[count_mat < 0] <- 0

col_data <- data.frame(sample    = colnames(count_mat),
                       row.names = colnames(count_mat))
dds  <- DESeqDataSetFromMatrix(count_mat, col_data, ~1)
keep <- rowSums(counts(dds) >= 10) >= 3
dds  <- dds[keep, ]
cat(sprintf("    Rows after filter (counts >= 10 in >= 3 samples): %d\n", sum(keep)))

dds     <- estimateSizeFactors(dds)
vst_mat <- assay(varianceStabilizingTransformation(dds, blind = TRUE))
cat("    VST complete\n")

# ORF proxies — subfam derived from vst_mat rownames (post-filter)
subfam    <- sub(":.*", "", rownames(vst_mat))
l1_idx    <- grepl(":L1:LINE", rownames(vst_mat))
vst_l1    <- vst_mat[l1_idx, ]
subfam_l1 <- subfam[l1_idx]

cat(sprintf("    Strato1 subfamilies (ORF1+ORF2): %d\n", sum(subfam_l1 %in% STRATO1)))
cat(sprintf("    Strato2 subfamilies (ORF1 only):  %d\n", sum(subfam_l1 %in% STRATO2)))

s1    <- colSums(vst_l1[subfam_l1 %in% STRATO1, , drop = FALSE])
s2    <- colSums(vst_l1[subfam_l1 %in% STRATO2, , drop = FALSE])
orf1p <- s1 + s2
orf2p <- s1

# Save VST matrix
write.table(as.data.frame(vst_mat),
            file.path(OUTPUT_DIR, "repeats_VST_normalized.tsv"),
            sep = "\t", quote = FALSE)

# ── 7. BUILD DATAFRAMES ───────────────────────────────────────────────────────

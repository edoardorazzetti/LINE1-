# ── 3. COLOUR PALETTES ────────────────────────────────────────────────────────
pal_tissue <- c("Healthy (GTEx)" = "#5B8DB8",
                "Adjacent"       = "#8CC78C",
                "Adenoma"        = "#E05C5C")
pal_grade  <- c("High"    = "#D62728",
                "Low"     = "#AEC7E8",
                "Unknown" = "#AAAAAA")

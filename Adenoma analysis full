                                check.names = FALSE, stringsAsFactors = FALSE)
gtex_sample_cols <- colnames(gtex_genes)[-(1:2)]

get_gtex <- function(gene) {
  row <- gtex_genes[gtex_genes$gene_name == gene, gtex_sample_cols, drop = FALSE]
  if (nrow(row) == 0) return(setNames(rep(NA_real_, length(gtex_sample_cols)),
                                       gtex_sample_cols))
  setNames(as.numeric(row[1, ]), gtex_sample_cols)
}

gtex_df <- data.frame(
  Sample = gtex_sample_cols,
  SIRT6  = get_gtex("SIRT6"), LDHA  = get_gtex("LDHA"),
  PDK1   = get_gtex("PDK1"),  PDK3  = get_gtex("PDK3"),
  L1MET  = NA_real_,          MET   = NA_real_,
  Tissue = "Healthy (GTEx)",
  Grade  = NA_character_,
  ORF1p  = NA_real_,          ORF2p = NA_real_,
  stringsAsFactors = FALSE
)

# ── 9. FIGURE 1 — ORF1p and ORF2p by adenoma grade ───────────────────────────
cat("[ 6/8 ] Plotting figures...\n")
cat("    Fig 1: ORF by grade\n")

orf_grade_df <- adn_df %>%
  dplyr::filter(!is.na(ORF1p) | !is.na(ORF2p)) %>%

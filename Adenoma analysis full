# ── 12. FIGURE 4 — Pearson correlation heatmap (adenomas only) ───────────────
cat("    Fig 4: correlation heatmap\n")

corr_df <- adn_df[, c("SIRT6","LDHA","PDK1","PDK3","MET","L1MET","ORF1p","ORF2p")]
colnames(corr_df)[colnames(corr_df) == "L1MET"] <- "L1-MET"
corr_df  <- corr_df[complete.cases(corr_df), ]

corr_mat <- cor(corr_df, use = "complete.obs", method = "pearson")
p_mat    <- cor_pmat(corr_df, use = "complete.obs")

fig4 <- ggcorrplot(corr_mat,
                   p.mat     = p_mat,
                   method    = "square",
                   type      = "full",
                   lab       = TRUE,
                   lab_size  = 3.5,
                   sig.level = 0.05,
                   insig     = "pch",
                   pch       = 4,
                   pch.cex   = 5,
                   colors    = c("#E05C5C", "white", "#5B8DB8"),
                   title     = "Pearson correlation — sporadic adenomas (n=24, excl. BRAF)",
                   ggtheme   = theme_classic(base_size = 12))

ggsave(file.path(OUTPUT_DIR, "fig4_correlation_heatmap.png"),
       fig4, dpi = 180, width = 8, height = 7)

# ── 13. FIGURE 5 — ORF1p + ORF2p vs SIRT6 and LDHA ──────────────────────────
cat("    Fig 5: ORF vs SIRT6/LDHA regressions\n")

reg_df <- adn_df %>%
  dplyr::filter(!is.na(ORF1p), !is.na(ORF2p)) %>%
  tidyr::pivot_longer(cols = c(ORF1p, ORF2p),
                      names_to = "ORF", values_to = "ORF_expr")

reg_plot <- function(data, x_var, x_label) {
  ggplot(data, aes(x = .data[[x_var]], y = ORF_expr,
                   colour = ORF, fill = ORF)) +
    geom_point(size = 2.5, alpha = 0.8) +
    geom_smooth(method = "lm", se = TRUE, linewidth = 0.9, alpha = 0.15) +
    scale_colour_manual(values = pal_orf) +
    scale_fill_manual(values   = pal_orf) +
    stat_cor(aes(group = ORF), method = "pearson",
             label.x.npc = "left", label.y.npc = "top", size = 3) +
    labs(title  = paste("ORF1p / ORF2p ~", x_label),
         x      = x_label,
         y      = "VST expression",
         colour = "ORF proxy",
         fill   = "ORF proxy") +
    theme_classic(base_size = 12) +
    theme(plot.title = element_text(face = "bold"))
}

fig5 <- reg_plot(reg_df, "SIRT6", "SIRT6 (mean TPM)") +
        reg_plot(reg_df, "LDHA",  "LDHA (mean TPM)") +
  plot_annotation(
    title    = "LINE-1 ORF proxies vs SIRT6 and LDHA — sporadic adenomas (n=24)",
    subtitle = "ORF1p = Strato1+Strato2 VST; ORF2p = Strato1 VST; genes = mean TPM",
    theme    = theme(plot.title    = element_text(face = "bold", size = 13),
                     plot.subtitle = element_text(size = 10))
  )

ggsave(file.path(OUTPUT_DIR, "fig5_ORF_vs_SIRT6_LDHA.png"),

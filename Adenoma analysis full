# ── 15. STATISTICAL SUMMARY ───────────────────────────────────────────────────
cat("[ 8/8 ] Statistical summary...\n")
cat("\n============================================================\n")
cat("CORRELATION ORF1p ~ ORF2p (VST)\n")
cat("============================================================\n")
ct <- cor.test(adn_df$ORF1p, adn_df$ORF2p, use = "complete.obs")
cat(sprintf("  R = %.4f   R² = %.4f   p = %.2e\n",
            ct$estimate, ct$estimate^2, ct$p.value))

cat("\n============================================================\n")
cat("REGRESSION SUMMARY (ORF VST ~ gene TPM)\n")
cat("============================================================\n")
models <- list(
  "ORF1p ~ SIRT6" = lm(ORF1p ~ SIRT6, data = adn_df),
  "ORF2p ~ SIRT6" = lm(ORF2p ~ SIRT6, data = adn_df),
  "ORF1p ~ LDHA"  = lm(ORF1p ~ LDHA,  data = adn_df),
  "ORF2p ~ LDHA"  = lm(ORF2p ~ LDHA,  data = adn_df)
)
for (nm in names(models)) {
  s   <- summary(models[[nm]])
  r2  <- s$r.squared
  p   <- s$coefficients[2, 4]
  sig <- ifelse(p < 0.001, "***", ifelse(p < 0.01, "**",
         ifelse(p < 0.05, "*", "ns")))
  cat(sprintf("  %-18s  R²=%.4f   p=%.4f   %s\n", nm, r2, p, sig))
}

